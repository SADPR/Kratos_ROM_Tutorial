<?xml version="1.0" encoding="utf-8"?><!-- -*- coding: utf-8; mode: SGML -*- -->
<Kratos_data version="9.5.1">
  <style show_menubutton_about="0" show_menubutton_search="1"/>
  <groups>
    <group n="Fluid" onoff="1" color="#26d1a8" type=""/>
    <group n="Inlet" onoff="1" color="#e0210f" type=""/>
    <group n="Outlet" onoff="1" color="#42eb71" type=""/>
    <group n="No_Slip_Walls" onoff="1" color="#3b3b3b" type=""/>
    <group n="No_Slip_Cylinder" onoff="1" color="#3b3b3b" type=""/>
    <group n="Inlet//inlet1" onoff="1" color="#00ff00" type=""/>
    <group n="Inlet//inlet2" onoff="1" color="#996600" type=""/>
  </groups>
  <units/>
  <!-- Fill this fields to automatically active an App without the init window -->
  <hiddenfield n="activeapp" active="0" v="Fluid" state="disabled"/>
  <value n="nDim" pn="Dimension" un="nDim" v="2D" state="disabled" values="undefined,2D,2Da,3D" dict="undefined,Undefined,2D,2D,2Da,2D axisymmetric,3D,3D" tree_state="close" actualize="1" actualize_tree="1"/>
  <appLink n="ThermicLauncher" public="1" pn="Thermic" active="0" appid="ThermicLauncher" prefix="ThermicLauncher"/>
  <appLink n="ConvectionDiffusion" public="0" pn="Convection-diffusion" active="0" appid="ConvectionDiffusion" prefix="CNVDFF"/>
  <appLink n="Structural" public="1" pn="Structural" active="0" appid="Structural" prefix="ST"/>
  <appLink n="FluidLauncher" public="1" pn="Fluid" active="0" appid="FluidLauncher" prefix="FLL"/>
  <container n="Fluid" pn="Fluid" icon="app" prefix="FL" tree_state="open" open_window="0">
    <container n="AnalysisType" pn="Analysis Type" help="Analysis information" icon="analysis" state="normal" open_window="0" tree_state="close">
      <value n="FreeSurface" pn="Free Surface" un="FLFreeSurface" v="No" values="Yes,No" help="Analysis type" state="hidden"/>
      <value n="SolStrat" pn="Solution Strategy" un="FLSolStrat" v="Monolithic" values="Monolithic,FractionalStep" dict="[GetSolutionStrategies App Fluid]" actualize_tree="1"/>
      <value n="Scheme" pn="Scheme" un="FLScheme" v="bossak" values="bossak,bdf2" dict="[GetSchemes]" actualize_tree="1"/>
    </container>
    <condition n="FluidParts" pn="Parts" ov="[CheckGeometry 1]" icon="reservoir16" help="Select your group" un="FLParts" update_proc="UpdateParts" tree_state="open">
      <value n="Element" pn="Element" v="" dict="[GetElements]" actualize="1" values="">
        <dependencies node="../value[@n!='Material']" actualize="1"/>
      </value>
      <value n="ConstitutiveLaw" pn="Fluid type" v="Newtonian2DLaw" actualize_tree="1" values="[GetConstitutiveLaws]" dict="[GetAllConstitutiveLaws]">
        <dependencies node="../value[@n!='Material']" actualize="1"/>
      </value>
      <value n="Material" pn="Material" state="disabled" help="Choose a material from the database" v="Air" values="[GetMaterialsList]">
        <edit_command n="Edit materials" pn="Edit materials" icon="refresh.png" proc="EditDatabaseList"/>
      </value>
      <value n="DENSITY" pn="Density" v="1.225" units="kg/m^3" unit_magnitude="Density" help="Density" string_is="double" state="[PartParamState]" show_in_window="1"/>
      <value n="DYNAMIC_VISCOSITY" pn="Dynamic viscosity" v="1.846e-5" units="kg/(m*s)" unit_magnitude="M/(L*T)" help="Set the dynamic viscosity." string_is="double" state="[PartParamState]" show_in_window="1"/>
      <value n="SOUND_VELOCITY" pn="Sound velocity" v="1.0e+12" units="m/s" unit_magnitude="L/T" help="Set the sound velocity." string_is="double" state="[PartParamState]" show_in_window="1"/>
      <group n="Fluid" tree_state="open">
        <value n="Element" pn="Element" v="QSVMS2D" dict="[GetElements]" actualize="1" values="QSVMS2D,DVMS2D,FIC2D" tree_state="close">
          <dependencies node="../value[@n!='Material']" actualize="1"/>
        </value>
        <value n="ConstitutiveLaw" pn="Fluid type" v="Newtonian2DLaw" actualize_tree="1" values="[GetConstitutiveLaws]" dict="[GetAllConstitutiveLaws]" tree_state="close">
          <dependencies node="../value[@n!='Material']" actualize="1"/>
        </value>
        <value n="Material" pn="Material" state="disabled" help="Choose a material from the database" v="Air" values="[GetMaterialsList]" tree_state="close">
          <edit_command n="Edit materials" pn="Edit materials" icon="refresh.png" proc="EditDatabaseList"/>
        </value>
        <value n="DENSITY" pn="Density" v="1.0" units="kg/m^3" unit_magnitude="Density" help="Density" string_is="double" state="[PartParamState]" show_in_window="1" tree_state="close"/>
        <value n="DYNAMIC_VISCOSITY" pn="Dynamic viscosity" v="0.002" units="kg/(m*s)" unit_magnitude="M/(L*T)" help="Set the dynamic viscosity." string_is="double" state="[PartParamState]" show_in_window="1" tree_state="active,open,selected"/>
        <value n="SOUND_VELOCITY" pn="Sound velocity" v="1.0e+12" units="m/s" unit_magnitude="L/T" help="Set the sound velocity." string_is="double" state="[PartParamState]" show_in_window="1"/>
      </group>
    </condition>
    <container n="Intervals" pn="Time intervals" un="Intervals" icon="time2" open_window="0" tree_state="close">
      <blockdata n="Interval" pn="Interval" name="Initial" sequence="1" icon="time3" editable_name="unique" sequence_type="non_void_disabled" help="Interval">
        <value n="IniTime" pn="Start time" v="0.0" state="disabled" help="When do the interval starts?"/>
        <value n="EndTime" pn="End time" v="0.0" state="disabled" help="When do the interval ends?"/>
      </blockdata>
      <blockdata n="Interval" pn="Interval" name="Total" sequence="1" icon="time3" editable_name="unique" sequence_type="non_void_disabled" help="Interval">
        <value n="IniTime" pn="Start time" v="0.0" state="disabled" help="When do the interval starts?"/>
        <value n="EndTime" pn="End time" v="End" state="disabled" help="When do the interval ends?"/>
      </blockdata>
      <blockdata n="Interval" pn="Interval" name="Custom1" sequence="1" icon="time3" editable_name="unique" sequence_type="non_void_disabled" help="Interval">
        <value n="IniTime" pn="Start time" v="0.0" help="When do the interval starts?"/>
        <value n="EndTime" pn="End time" v="0.5" help="When do the interval ends?"/>
      </blockdata>
      <blockdata n="Interval" pn="Interval" name="inlet1" sequence="1" editable_name="unique" sequence_type="non_void_disabled" help="Interval">
        <value n="IniTime" pn="Start time" v="0" help="When do the interval starts?"/>
        <value n="EndTime" pn="End time" v="1" help="When do the interval ends?"/>
      </blockdata>
      <blockdata n="Interval" pn="Interval" name="inlet2" sequence="1" editable_name="unique" sequence_type="non_void_disabled" help="Interval">
        <value n="IniTime" pn="Start time" v="1" help="When do the interval starts?"/>
        <value n="EndTime" pn="End time" v="End" help="When do the interval ends?"/>
      </blockdata>
    </container>
    <container n="InitialConditions" pn="Initial Conditions" un="FLNodalConditions" icon="air" open_window="0" tree_state="open">
      <condition n="VELOCITY" pn="Velocity" ov="point,line,surface" ovm="" icon="shells16" help="Velocity" state="[CheckNodalConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
        <value n="selector_component_X" pn="Component X" v="ByValue" values="ByFunction,ByValue,Not" dict="ByFunction,By function,ByValue,By value,Not,Not set" state="[ConditionParameterState]" help="Component" show_in_window="1" cal_state="normal">
          <dependencies value="Not" node="../value[@n='value_component_X']" att1="state" v1="hidden"/>
          <dependencies value="Not" node="../value[@n='function_component_X']" att1="state" v1="hidden"/>
          <dependencies value="ByValue" node="../value[@n='value_component_X']" att1="state" v1="normal"/>
          <dependencies value="ByFunction" node="../value[@n='value_component_X']" att1="state" v1="hidden"/>
          <dependencies value="ByValue" node="../value[@n='function_component_X']" att1="state" v1="hidden"/>
          <dependencies value="ByFunction" node="../value[@n='function_component_X']" att1="state" v1="normal"/>
        </value>
        <value n="function_component_X" pn="Function X (x,y,z,t)" v="2*x" help="Component" state="hidden"/>
        <value n="value_component_X" wn="VELOCITY _X" pn="Value X" v="0.0" units="m/s" unit_magnitude="Velocity" help="Component" show_in_window="1"/>
        <value n="selector_component_Y" pn="Component Y" v="ByValue" values="ByFunction,ByValue,Not" dict="ByFunction,By function,ByValue,By value,Not,Not set" state="[ConditionParameterState]" help="Component" show_in_window="1" cal_state="normal">
          <dependencies value="Not" node="../value[@n='value_component_Y']" att1="state" v1="hidden"/>
          <dependencies value="Not" node="../value[@n='function_component_Y']" att1="state" v1="hidden"/>
          <dependencies value="ByValue" node="../value[@n='value_component_Y']" att1="state" v1="normal"/>
          <dependencies value="ByFunction" node="../value[@n='value_component_Y']" att1="state" v1="hidden"/>
          <dependencies value="ByValue" node="../value[@n='function_component_Y']" att1="state" v1="hidden"/>
          <dependencies value="ByFunction" node="../value[@n='function_component_Y']" att1="state" v1="normal"/>
        </value>
        <value n="function_component_Y" pn="Function Y (x,y,z,t)" v="2*x" help="Component" state="hidden"/>
        <value n="value_component_Y" wn="VELOCITY _Y" pn="Value Y" v="0.0" units="m/s" unit_magnitude="Velocity" help="Component" show_in_window="1"/>
        <value n="selector_component_Z" pn="Component Z" v="ByValue" values="ByFunction,ByValue,Not" dict="ByFunction,By function,ByValue,By value,Not,Not set" state="[CheckDimension 3D]" help="Component" show_in_window="1">
          <dependencies value="Not" node="../value[@n='value_component_Z']" att1="state" v1="hidden"/>
          <dependencies value="Not" node="../value[@n='function_component_Z']" att1="state" v1="hidden"/>
          <dependencies value="ByValue" node="../value[@n='value_component_Z']" att1="state" v1="normal"/>
          <dependencies value="ByFunction" node="../value[@n='value_component_Z']" att1="state" v1="hidden"/>
          <dependencies value="ByValue" node="../value[@n='function_component_Z']" att1="state" v1="hidden"/>
          <dependencies value="ByFunction" node="../value[@n='function_component_Z']" att1="state" v1="normal"/>
        </value>
        <value n="function_component_Z" pn="Function Z (x,y,z,t)" v="2*x" help="Component" state="[CheckDimension 3D]"/>
        <value n="value_component_Z" wn="VELOCITY _Z" pn="Value Z" v="0.0" units="m/s" unit_magnitude="Velocity" help="Component" state="[CheckDimension 3D]" show_in_window="1"/>
      </condition>
      <condition n="PRESSURE" pn="Pressure" ov="point,line,surface" ovm="" icon="shells16" help="Pressure" state="[CheckNodalConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
        <value n="constrained" pn="Imposed" v="false" values="true,false" help="Imposed" state="hidden" show_in_window="1"/>
        <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
          <dependencies value="No" node="../value[@n='value']" att1="state" v1="normal"/>
          <dependencies value="Yes" node="../value[@n='value']" att1="state" v1="hidden"/>
          <dependencies value="No" node="../value[@n='function_value']" att1="state" v1="hidden"/>
          <dependencies value="Yes" node="../value[@n='function_value']" att1="state" v1="normal"/>
        </value>
        <value n="function_value" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
        <value n="value" pn="Value" v="0.0" units="Pa" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
      </condition>
    </container>
    <container n="BoundaryConditions" pn="Conditions" un="FLBC" icon="nodal" open_window="0" tree_state="open">
      <condition n="AutomaticInlet2D" pn="Automatic inlet velocity" ov="line" ovm="" icon="shells16" help="Automatic inlet velocity" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
        <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
          <dependencies value="No" node="../value[@n='modulus']" att1="state" v1="normal"/>
          <dependencies value="Yes" node="../value[@n='modulus']" att1="state" v1="hidden"/>
          <dependencies value="No" node="../value[@n='function_modulus']" att1="state" v1="hidden"/>
          <dependencies value="Yes" node="../value[@n='function_modulus']" att1="state" v1="normal"/>
        </value>
        <value n="function_modulus" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
        <value n="modulus" pn="Value" v="1.0" units="m/s" unit_magnitude="Velocity" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
        <value n="direction" pn="Normal direction" v="automatic_inwards_normal" values="automatic_inwards_normal,automatic_outwards_normal" dict="automatic_inwards_normal,Inwards,automatic_outwards_normal,Outwards" state="[ConditionParameterState]" help="Normal direction" show_in_window="1"/>
        <value n="Interval" pn="Time interval" v="Total" values="[getIntervals]" help="Automatic inlet velocity" state="normal"/>
        <group n="Inlet//inlet1" ov="line">
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="Yes" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='modulus']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='modulus']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_modulus']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_modulus']" att1="state" v1="normal"/>
          </value>
          <value n="function_modulus" pn="Function" v="6*y*(1-y)*sin(pi*t*0.5)" help="Value" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="modulus" pn="Value" v="1.0" units="m/s" unit_magnitude="Velocity" help="Value" string_is="double" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="direction" pn="Normal direction" v="automatic_inwards_normal" values="automatic_inwards_normal,automatic_outwards_normal" dict="automatic_inwards_normal,Inwards,automatic_outwards_normal,Outwards" state="[ConditionParameterState]" help="Normal direction" show_in_window="1" cal_state="normal"/>
          <value n="Interval" pn="Time interval" v="inlet1" values="[getIntervals]" help="Automatic inlet velocity" state="normal"/>
        </group>
        <group n="Inlet//inlet2" ov="line">
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="Yes" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='modulus']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='modulus']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_modulus']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_modulus']" att1="state" v1="normal"/>
          </value>
          <value n="function_modulus" pn="Function" v="6*y*(1-y)" help="Value" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="modulus" pn="Value" v="1.0" units="m/s" unit_magnitude="Velocity" help="Value" string_is="double" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="direction" pn="Normal direction" v="automatic_inwards_normal" values="automatic_inwards_normal,automatic_outwards_normal" dict="automatic_inwards_normal,Inwards,automatic_outwards_normal,Outwards" state="[ConditionParameterState]" help="Normal direction" show_in_window="1" cal_state="normal"/>
          <value n="Interval" pn="Time interval" v="inlet2" values="[getIntervals]" help="Automatic inlet velocity" state="normal"/>
        </group>
      </condition>
      <condition n="AutomaticInlet3D" pn="Automatic inlet velocity" ov="surface" ovm="" icon="shells16" help="Automatic inlet velocity" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree">
        <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
          <dependencies value="No" node="../value[@n='modulus']" att1="state" v1="normal"/>
          <dependencies value="Yes" node="../value[@n='modulus']" att1="state" v1="hidden"/>
          <dependencies value="No" node="../value[@n='function_modulus']" att1="state" v1="hidden"/>
          <dependencies value="Yes" node="../value[@n='function_modulus']" att1="state" v1="normal"/>
        </value>
        <value n="function_modulus" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
        <value n="modulus" pn="Value" v="1.0" units="m/s" unit_magnitude="Velocity" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
        <value n="direction" pn="Normal direction" v="automatic_inwards_normal" values="automatic_inwards_normal,automatic_outwards_normal" dict="automatic_inwards_normal,Inwards,automatic_outwards_normal,Outwards" state="[ConditionParameterState]" help="Normal direction" show_in_window="1"/>
        <value n="Interval" pn="Time interval" v="Total" values="[getIntervals]" help="Automatic inlet velocity" state="normal"/>
      </condition>
      <condition n="Outlet2D" pn="Outlet pressure" ov="line" ovm="" icon="shells16" help="Fixes the pressure" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
        <value n="constrained" pn="Imposed" v="true" values="true,false" help="Imposed" state="hidden" show_in_window="1"/>
        <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
          <dependencies value="No" node="../value[@n='value']" att1="state" v1="normal"/>
          <dependencies value="Yes" node="../value[@n='value']" att1="state" v1="hidden"/>
          <dependencies value="No" node="../value[@n='function_value']" att1="state" v1="hidden"/>
          <dependencies value="Yes" node="../value[@n='function_value']" att1="state" v1="normal"/>
        </value>
        <value n="function_value" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
        <value n="value" pn="Value" v="0.0" units="Pa" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
        <value n="hydrostatic_outlet" pn="Add hydrostatic contribution" v="false" values="true,false" help="If true, adds the hydrostatic pressure component to the outlet pressure." actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
          <dependencies condition="@v='true'" node="../value[@n='h_top']" att1="state" v1="normal"/>
          <dependencies condition="@v!='true'" node="../value[@n='h_top']" att1="state" v1="hidden"/>
        </value>
        <value n="h_top" pn="Top height" v="0.0" units="m" unit_magnitude="L" help="Fluid height above the outlet. If equals 0.0 triangular distribution is considered." string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden"/>
        <group n="Outlet" ov="line">
          <value n="constrained" pn="Imposed" v="true" values="true,false" help="Imposed" state="hidden" show_in_window="1"/>
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='value']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='value']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_value']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_value']" att1="state" v1="normal"/>
          </value>
          <value n="function_value" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="value" pn="Value" v="0.0" units="" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="hydrostatic_outlet" pn="Add hydrostatic contribution" v="false" values="true,false" help="If true, adds the hydrostatic pressure component to the outlet pressure." actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies condition="@v='true'" node="../value[@n='h_top']" att1="state" v1="normal"/>
            <dependencies condition="@v!='true'" node="../value[@n='h_top']" att1="state" v1="hidden"/>
          </value>
          <value n="h_top" pn="Top height" v="0.0" units="m" unit_magnitude="L" help="Fluid height above the outlet. If equals 0.0 triangular distribution is considered." string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden"/>
        </group>
      </condition>
      <condition n="Outlet3D" pn="Outlet pressure" ov="surface" ovm="" icon="shells16" help="Fixes the pressure to a constant scalar value." state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree">
        <value n="constrained" pn="Imposed" v="true" values="true,false" help="Imposed" state="hidden" show_in_window="1"/>
        <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
          <dependencies value="No" node="../value[@n='value']" att1="state" v1="normal"/>
          <dependencies value="Yes" node="../value[@n='value']" att1="state" v1="hidden"/>
          <dependencies value="No" node="../value[@n='function_value']" att1="state" v1="hidden"/>
          <dependencies value="Yes" node="../value[@n='function_value']" att1="state" v1="normal"/>
        </value>
        <value n="function_value" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
        <value n="value" pn="Value" v="0.0" units="Pa" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
        <value n="hydrostatic_outlet" pn="Add hydrostatic contribution" v="false" values="true,false" help="If true, adds the hydrostatic pressure component to the outlet pressure." actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
          <dependencies condition="@v='true'" node="../value[@n='h_top']" att1="state" v1="normal"/>
          <dependencies condition="@v!='true'" node="../value[@n='h_top']" att1="state" v1="hidden"/>
        </value>
        <value n="h_top" pn="Top height" v="0.0" units="m" unit_magnitude="L" help="Fluid height above the outlet. If equals 0.0 triangular distribution is considered." string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden"/>
      </condition>
      <condition n="Slip2D" pn="Slip" ov="line" ovm="" icon="shells16" help="Slip" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close"/>
      <condition n="Slip3D" pn="Slip" ov="surface" ovm="" icon="shells16" help="Slip" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree"/>
      <condition n="NoSlip2D" pn="No Slip" ov="line" ovm="" icon="shells16" help="No Slip" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
        <group n="No_Slip_Walls" ov="line"/>
        <group n="No_Slip_Cylinder" ov="line"/>
      </condition>
